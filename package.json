{
  "name": "quick-stack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev-live": "tsc --project tsconfig.server.json && tsc-alias -p tsconfig.server.json && node dist/server.js",
    "build": "next build && tsc --project tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "build:cli": "pnpm --filter @quickstack/cli build && pnpm run build:cli:all",
    "build:cli:all": "bun build packages/cli/src/main.ts --compile --target=bun-linux-x64 --define __QUICKSTACK_CLI_VERSION__='\"0.1.0\"' --outfile public/cli/0.1.0/linux-x64/quickstack && bun build packages/cli/src/main.ts --compile --target=bun-linux-arm64 --define __QUICKSTACK_CLI_VERSION__='\"0.1.0\"' --outfile public/cli/0.1.0/linux-arm64/quickstack && bun build packages/cli/src/main.ts --compile --target=bun-darwin-x64 --define __QUICKSTACK_CLI_VERSION__='\"0.1.0\"' --outfile public/cli/0.1.0/darwin-x64/quickstack && bun build packages/cli/src/main.ts --compile --target=bun-darwin-arm64 --define __QUICKSTACK_CLI_VERSION__='\"0.1.0\"' --outfile public/cli/0.1.0/darwin-arm64/quickstack",
    "start": "next start",
    "start-prod": "cross-env NODE_ENV=production node dist/server.js",
    "prisma-generate": "pnpm exec prisma generate && node ./fix-wrong-zod-imports.js",
    "prisma-generate-build": "pnpm exec prisma generate && node ./fix-wrong-zod-imports.js",
    "prisma-migrate": "pnpm exec prisma migrate dev --name migration",
    "prisma-deploy": "pnpm exec prisma migrate deploy",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@hookform/resolvers": "^3.9.0",
    "@kubernetes/client-node": "^1.4.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-hover-card": "^1.1.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-table": "^8.20.5",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.0",
    "bcrypt": "^6.0.0",
    "bufferutil": "^4.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.0",
    "cron-parser": "^4.9.0",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.465.0",
    "moment": "^2.30.1",
    "next": "15.5.18",
    "next-auth": "^4.24.14",
    "next-themes": "^0.3.0",
    "node-schedule": "^2.1.1",
    "otpauth": "^9.3.4",
    "prisma": "7.8.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "recharts": "^2.15.4",
    "reflect-metadata": "^0.2.2",
    "simple-git": "^3.36.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "tar": "^7.5.11",
    "ts-node": "^10.9.2",
    "typedi": "^0.10.0",
    "vaul": "^1.1.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "bcrypt",
      "better-sqlite3",
      "bufferutil",
      "cpu-features",
      "prisma",
      "protobufjs",
      "sharp",
      "ssh2",
      "unrs-resolver"
    ],
    "overrides": {
      "@babel/runtime": "^7.26.10",
      "@eslint/plugin-kit": "^0.3.4",
      "@hono/node-server": "^1.19.13",
      "ajv": "^6.14.0",
      "brace-expansion": "^1.1.13",
      "cross-spawn": "^7.0.5",
      "diff": "^4.0.4",
      "flatted": "^3.4.2",
      "glob": "^10.5.0",
      "js-yaml": "^4.1.1",
      "lodash": "^4.18.1",
      "minimatch": "^3.1.4",
      "picomatch": "^2.3.2",
      "postcss": "^8.5.10",
      "socket.io-parser": "^4.2.6",
      "yaml": "^2.8.3"
    }
  },
  "devDependencies": {
    "@testcontainers/k3s": "^11.14.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.7.9",
    "@types/node-schedule": "^2.1.7",
    "@types/nodemailer": "^6.4.16",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.13.0",
    "eslint-config-next": "15.5.18",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4",
    "zod-prisma": "^0.5.4"
  },
  "packageManager": "pnpm@10.11.0"
}
