{
  "name": "@quickstack/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": "1.3.12"
  },
  "bin": {
    "quickstack": "./dist/quickstack"
  },
  "scripts": {
    "build": "bun build src/main.ts --compile --target=bun-darwin-arm64 --define __QUICKSTACK_CLI_VERSION__='\"'$npm_package_version'\"' --outfile dist/quickstack",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
